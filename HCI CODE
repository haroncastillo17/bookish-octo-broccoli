color:white;
border:none;
padding:10px;
margin:5px;
cursor:pointer;
}

/* LOGIN */

.loginbuttons{
position:fixed;
right:10px;
top:100px;
}

.loginbox{
display:none;
position:fixed;
right:10px;
top:170px;
background:#f5f5f5;
padding:15px;
border:1px solid #ccc;
width:200px;
}

footer{
background:red;
color:white;
text-align:center;
padding:15px;
margin-top:20px;
